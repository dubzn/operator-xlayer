# X Layer RPC
RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196

# Operator wallet (submits txs, receives fees)
OPERATOR_PRIVATE_KEY=0x...

# Deployed contract addresses
VAULT_ADDRESS=0x...
REGISTRY_ADDRESS=0x...
FACTORY_ADDRESS=0x...

# Fee config
OPERATOR_FEE=1000000        # 1 USDT (6 decimals)
FEE_TOKEN=0x...             # USDT address on X Layer

# DEX mode: "true" for testnet MockRouter, "false" for OKX DEX API
USE_MOCK_ROUTER=false

# OKX DEX API credentials (required when USE_MOCK_ROUTER=false)
# Get credentials at https://web3.okx.com/build/dev-portal
OKX_API_KEY=your-api-key
OKX_SECRET_KEY=your-secret-key
OKX_PASSPHRASE=your-passphrase
OKX_PROJECT_ID=your-project-id
DEX_SLIPPAGE=0.01

# Server
PORT=3000
