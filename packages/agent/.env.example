# X Layer RPC
RPC_URL=https://testrpc.xlayer.tech/terigon
CHAIN_ID=1952

# Controller wallet (signs intents, pays fees)
CONTROLLER_PRIVATE_KEY=0x...

# Operator backend URL
OPERATOR_URL=http://localhost:3000

# Vault and token addresses
VAULT_ADDRESS=0x...
TOKEN_IN=0x...              # base token (e.g. USDT)
TOKEN_OUT=0x...             # target token (e.g. USDC)
FEE_TOKEN=0x...             # token for paying operator fee

# Swap config
SWAP_AMOUNT=1000000         # 1 USDT (6 decimals)

# Agent behavior
INTERVAL_MS=30000           # seconds between rounds
MAX_ROUNDS=0                # 0 = unlimited, 1 = single-shot
