# X Layer RPC
RPC_URL=https://rpc.xlayer.tech
CHAIN_ID=196

# Controller wallet (signs intents, pays fees)
CONTROLLER_PRIVATE_KEY=0x...

# Operator backend URL
OPERATOR_URL=http://localhost:3000

# Vault and execution venue
# Use VAULT_ADDRESS for single-vault runs or VAULT_ADDRESSES for multi-vault e2e tests.
# The single-shot demo command (`npm run demo:swap ...`) receives the vault and token pair via CLI args.
VAULT_ADDRESS=0x...
VAULT_ADDRESSES=
SWAP_ADAPTER_ADDRESS=0x...

# Swap pair
TOKEN_IN=0x...
TOKEN_OUT=0x...
FEE_TOKEN=0x...

# Swap config
SWAP_AMOUNT=1000000
OKX_DEX_IDS=
OKX_EXCLUDE_DEX_IDS=

# Agent behavior
AUTO_WATCH_VAULTS=true
INTERVAL_MS=30000
MAX_ROUNDS=0
