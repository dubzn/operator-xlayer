{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@x402-operator/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../shared" }
  ]
}
